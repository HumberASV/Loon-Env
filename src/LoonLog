# Logger for the Loon-E project. It logs user sessions, processes, and checks for the Docker daemon.
#
# Why is it using a KNOWN_USERS_FILE? 
#   Because Loon-e is blind and can't tell who you are.
#   No, it's because the log in is dysfunct and we want to be able to track users. 
#   robo users are users that the system can't identify, so we ask them for a name and save it to a file.
# Usage:
#   This is to be invoked in bashrc.
#   ensure the the script is invoked in bash_logout to log when users exit the terminal.

# ------------------ CONSTANTS ------------------
# Max size for the log file in bytes (e.g., 5 MiB)

MAX_LOG_SIZE=$((5 * 1024 * 1024)) 

LOG_FILE="${LOG_FILE:-log.txt}"

# The file to store known users. Each line is in the format "user:given_name:terminal_count:message".
KNOWN_USERS_FILE="${KNOWN_USERS_FILE:-known_users.txt}"

DEFAULT_USER="robo" # Change this to whatever you set your default user is.

# Ensure directory structure exists
mkdir -p "$(dirname "$KNOWN_USERS_FILE")"
mkdir -p "$(dirname "$LOG_FILE")"

touch "$KNOWN_USERS_FILE"
touch "$LOG_FILE"

# We can't make objects so pretend these are objects functions
# ------------------ User Functions ------------------
# User fields:
# - user - the name of the user (from whoami)
# - given_name - the name given by the user if the username is $DEFAULT_USER
# - terminal_count - the number of terminals the user has open, determined by counting bash processes
# - warn_msg - a warning message set by the user to be displayed to all users when they log in


# Function to add User in KNOWN_USERS_FILE
# Creates a temp file and then replaces the $KNOWN_USER_FILE
# Parameters:
#   user - the user's name (defaults to $DEFAULT_USER)
#   given_name - the name given by the user if the user is $DEFAULT_USER
#   terminal_count - the number of terminals opened (optional and best left empty)
#   message - the message the user will display as a "wall" warning message (optional best left empty)
create_user() {
    # Parameter definition
    local user="${1:-$DEFAULT_USER}"
    local given_name="${2:-$DEFAULT_USER}"
    local terminal_count="${3:-1}" # Default to 1 terminal if not provided
    local message="${4:-}" # Default to no message if not provided

    echo "$user:$given_name:$terminal_count:$message" >> "$KNOWN_USERS_FILE"
}

# Function to add or update a user in KNOWN_USERS_FILE.
# If the user exists, terminal_count is incremented by the provided amount.
add_user() {
    local user="${1:-$DEFAULT_USER}"
    local given_name="${2:-$user}"
    local terminal_count="${3:-1}"
    local message="${4:-}"

    if ! [[ "$terminal_count" =~ ^-?[0-9]+$ ]]; then
        echo "add_user: terminal_count must be an integer" >&2
        return 1
    fi

    local user_line
    user_line=$(read_user "$user")
    if [ -n "$user_line" ]; then
        local current_count
        current_count=$(echo "$user_line" | cut -d: -f3)
        if ! [[ "$current_count" =~ ^-?[0-9]+$ ]]; then
            echo "add_user: existing terminal_count for '$user' is invalid" >&2
            return 1
        fi

        update_user "$user" "$user" "$given_name" "$((current_count + terminal_count))" "$message"
        return $?
    fi

    create_user "$user" "$given_name" "$terminal_count" "$message"
}

# Function to find and output matching line in KNOWN_USERS_FILE
# Parameters:
#   username - the user's given_name or user name.
# returns:
#   Either
#       - Line consisting of user:given_name:terminal_count:message
#       - nothing (not found)
read_user(){
    # Parameter definition
    local username="$1"

    awk -F: -v username="$username" '
        $1 == username || $2 == username {
            print
            exit
        }
    ' "$KNOWN_USERS_FILE"
}

# Function to update User line in $KNOWN_USER_FILE
# Creates a temp file and then replaces the $KNOWN_USER_FILE
# Parameters:
#   username - the user's given_name or user name to match for the update
#   new_user - the new user name (optional, leave empty to keep unchanged)
#   new_given_name - the new given name (optional, leave empty to keep unchanged)
#   new_terminal_count - the new terminal count (optional, leave empty to keep unchanged)
#   new_message - the new message (optional, leave empty to keep unchanged)
# returns:
#   0 if user was found and updated, 1 if user was not found or
#   an error occurred   
update_user(){
    local username="$1"
    local new_user="$2"
    local new_given_name="$3"
    local new_terminal_count="$4"
    local new_message="$5"

    if [ -z "$username" ]; then
        echo "update_user: username is required" >&2
        return 1
    fi

    local temp_file
    temp_file=$(mktemp)

    awk -F: -v OFS=":" \
        -v username="$username" \
        -v new_user="$new_user" \
        -v new_given_name="$new_given_name" \
        -v new_terminal_count="$new_terminal_count" \
        -v new_message="$new_message" '
        BEGIN { updated=0 }
        ($1 == username || $2 == username) && updated == 0 {
            updated=1
            user = (new_user != "" ? new_user : $1)
            given_name = (new_given_name != "" ? new_given_name : $2)
            terminal_count = (new_terminal_count != "" ? new_terminal_count : $3)
            message = (new_message != "" ? new_message : $4)
            print user, given_name, terminal_count, message
            next
        }
        { print }
        END {
            if (updated == 0) {
                exit 2
            }
        }
    ' "$KNOWN_USERS_FILE" > "$temp_file"

    case $? in
        0)
            mv "$temp_file" "$KNOWN_USERS_FILE"
            ;;
        2)
            rm -f "$temp_file"
            return 1
            ;;
        *)
            rm -f "$temp_file"
            return 1
            ;;
    esac
}

# Function to delete specified user from $KNOWN_USERFILE
# Creates a temp file and then replaces the $KNOWN_USER_FILE
# Parameters:
#   username - the user's given_name or user name to match for deletion
# returns:
#   0 if user was found and deleted, 1 if user was not found or
#   an error occurred
delete_user(){
    local username="$1"

    # Username requirement
    if [ -z "$username" ]; then
        echo "delete_user: username is required" >&2
        return 1
    fi

    local temp_file
    temp_file=$(mktemp)

    awk -F: -v username="$username" '
        BEGIN { deleted=0 }
        $1 == username || $2 == username {
            deleted=1
            next
        }
        { print }
        END {
            if (deleted == 0) {
                exit 2
            }
        }
    ' "$KNOWN_USERS_FILE" > "$temp_file"

    case $? in
        0)
            mv "$temp_file" "$KNOWN_USERS_FILE"
            ;;
        2)
            rm -f "$temp_file"
            return 1
            ;;
        *)
            rm -f "$temp_file"
            return 1
            ;;
    esac
}

# ------------------ User Attribute Functions ------------------

# Function to edit terminal count of specified user from KNOWN_USERS_FILE
# Set amount to a negative number to decrement and positive number to increment.
# Instead of crud function this is going to be called often.
# Parameters:
#   username - the user's given_name or user name to match for session removal
#   amount - the amount to decrement the terminal count by (optional, defaults to 1)
# Returns:
#   0 if user was found and updated, 1 if user was not found or
#   an error occurred
update_session() {
    local username="$1"
    local amount="${2:-1}" # Default to 1 terminal if not provided

    local user_line=$(read_user "$username")
    if [ -z "$user_line" ]; then
        echo "User '$username' not found in $KNOWN_USERS_FILE" >&2
        return 1
    fi

    # Determine if user has less than or equal to 0 terminals after applying the change, if so remove user entirely
    local terminal_count=$(echo "$user_line" | cut -d: -f3)
    if ! [[ "$terminal_count" =~ ^-?[0-9]+$ ]] || ! [[ "$amount" =~ ^-?[0-9]+$ ]]; then
        echo "Error: terminal count or decrement amount for user '$username' is not a valid integer." >&2
        return 1
    fi

    local new_terminal_count=$((terminal_count + amount))

    if [ "$new_terminal_count" -le 0 ]; then
        delete_user "$username"
        return $?
    fi

    # if can decrement without going to 0, then just decrement
    update_user "$username" "" "" "$new_terminal_count" ""
    return $?
}

# Function to update warning message
# Parameters:
#   username - the user's given_name or user name to match for session removal
#   warn_msg - the warning message to set for the user
# Returns:
#   0 if user was found and updated, 1 if user was not found or
#   an error occurred
update_warning() {
    local username="$1"
    local warn_msg="$2"

    if [ -z "$username" ]; then
        echo "update_warning: username is required" >&2
        return 1
    fi

    if [[ "$warn_msg" == *":"* ]]; then
        echo "update_warning: warn_msg cannot contain ':'" >&2
        return 1
    fi

    if [[ "$warn_msg" == *$'\n'* ]]; then
        echo "update_warning: warn_msg cannot contain newlines" >&2
        return 1
    fi

    local temp_file
    temp_file=$(mktemp)

    awk -F: -v OFS=":" -v username="$username" -v warn_msg="$warn_msg" '
        BEGIN { updated=0 }
        ($1 == username || $2 == username) && updated == 0 {
            updated=1
            print $1, $2, $3, warn_msg
            next
        }
        { print }
        END {
            if (updated == 0) {
                exit 2
            }
        }
    ' "$KNOWN_USERS_FILE" > "$temp_file"

    case $? in
        0)
            mv "$temp_file" "$KNOWN_USERS_FILE"
            ;;
        2)
            rm -f "$temp_file"
            return 1
            ;;
        *)
            rm -f "$temp_file"
            return 1
            ;;
    esac
}

# Returns the warning message of specified user
# Parameters:
#   username - the user's given_name or user name to match for session removal
# Returns:
#  the warning message of the user, or empty string if not found or no message set
get_warning() {
    local user="$1"
    local user_line
    user_line=$(read_user "$user")

    if [ -z "$user_line" ]; then
        return 1
    fi

    echo "$user_line" | cut -d: -f4-
    return 0
}

# Complex set of defensive loops to add warning message to specified user
# Parameters:
#  username - the user's given_name or user name to match for session removal
#  warn_msg - the warning message to set for the user (optional, will prompt if not provided)
# Returns:
#  0 if user was found, and/or updated (returns 0 if not updated but user was found)
#  1 if user was not found or error occurred
add_warning() {
    local user="$1"
    local warn_msg="${2:-}" # Optional second argument for the warning message, but we'll prompt if it's not provided
    local warning
    warning=$(get_warning "$user")
    if [ -n "$warning" ]; then
        echo "User $user already has a warning message set: $warning"
        read -p "Do you want to overwrite the existing warning message? (y/n) " confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            echo "Keeping existing warning message."
            return 0
        fi
        echo "Overwriting existing warning message."
        # continue to overwrite the warning message
    fi

    while true; do

        if [ -z "$warn_msg" ]; then # Validate that the warning message is not empty
            echo "Warning message cannot be empty. Please enter a warning message."
        elif [[ "$warn_msg" == *":"* ]]; then # this is due to the delimiter used in KNOWN_USERS_FILE
            echo "Warning message cannot contain colons. Please enter a warning message without colons."
        elif [[ "$warn_msg" == *$'\n'* ]]; then # This is due to how we read the data on KNOWN_USERS_FILE
            echo "Warning message cannot contain newlines. Please enter a warning message without newlines."
        else
            read -p "Are you sure you want to set the warning message to '$warn_msg'? (y/n) " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                echo "Setting warning message to '$warn_msg'"
                if ! update_warning "$user" "$warn_msg"; then
                    echo "Failed to set warning message for user $user" >&2
                    return 1
                fi
                echo "Warning message set successfully."
                break
            else
                echo "Warning message update cancelled. Please enter a new warning message."
                continue
            fi
        fi
        # Down here to emulate do while
        read -p "Enter a warning message to display to all users on login: " warn_msg

    done
}

# Function to remove warning message for specified user
# Parameters:
#  username - the user's given_name or user name to match for session removal
# Returns:
#  0 if user was found and warning message removed, 1 if user was not found or error occurred
remove_warning() {
    local user="$1"

    if [ -z "$user" ]; then
        echo "remove_warning: username is required" >&2
        return 1
    fi

    echo "Removing warning message for user $user"
    if ! update_warning "$user" ""; then
        echo "Failed to remove warning message for user $user" >&2
        return 1
    fi
    echo "Warning message removed successfully."
}


# at the bottom of the functions section is the parse arguements function invokation, which is the main entry point.
# ------------------ FUNCTIONS ------------------

# Function to get the username, with special handling for "robo" users
# parameters:
#   none, but relies on $DEFAULT_USER and $KNOWN_USERS_FILE
# returns:
#   0 if user was successfully obtained and added to $KNOWN_USERS_FILE, 1 if an error occurred
get_user() {
    local prompt_for_robo="${1:-1}"
    local given_name=""

    user=$(whoami)
    if [ "$DEFAULT_USER" == "$user" ]; then
        if [ "$prompt_for_robo" -eq 1 ]; then
            echo "Loon-E is blind and can't tell who you are"
            echo "Login with your username or ask a sysadmin to add you"

            while true; do
                read -p "What is your name: " given_name

                if [ -z "$given_name" ]; then
                    echo "Name cannot be empty. Please enter your name."
                    continue
                fi

                if command -v "$given_name" >/dev/null 2>&1; then
                    echo "The name '$given_name' is a command name. Please choose a different username."
                    continue
                fi

                if awk -F: -v user="$DEFAULT_USER" -v given_name="$given_name" '$1 == user && $2 == given_name { found=1; exit } END { exit !found }' "$KNOWN_USERS_FILE"; then
                    echo "The name '$given_name' is already registered. Please enter a different name."
                    continue
                fi

                if [[ "$given_name" == *":"* ]]; then
                    echo "Name cannot contain colons. Please enter a name without colons."
                    continue
                fi

                if [[ "$given_name" == *$'\n'* ]]; then
                    echo "Name cannot contain newlines. Please enter a name without newlines."
                    continue
                fi

                break
            done
        else
            given_name="$DEFAULT_USER"
        fi

        if ! add_user "$DEFAULT_USER" "$given_name"; then
            echo "Failed to add user '$DEFAULT_USER' to $KNOWN_USERS_FILE" >&2
            return 1
        fi
    else
        if ! add_user "$user" "$user"; then
            echo "Failed to add user '$user' to $KNOWN_USERS_FILE" >&2
            return 1
        fi
    fi

    echo "Saved '$user' to $KNOWN_USERS_FILE"
    echo "Welcome Aboard $user!"
}

# Function to determine log size
get_log_size() {
    if [ -f "$LOG_FILE" ]; then
        log_size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    else
        log_size=0
    fi
}

# Function to check log size and warn if it's too large
check_log_size() {
    get_log_size
    if [ "$log_size" -ge "$MAX_LOG_SIZE" ]; then
        echo "Warning: $LOG_FILE is too large ($log_size bytes, max $MAX_LOG_SIZE bytes)."
        echo "Consider backing up or clearing it."
    fi
}

# Function to check if the user is a sys-admin
# also stupid but whatever
is_sysadmin() {
    if id -nG "$user" | grep -qwE 'sudo|wheel'; then
        return 0
    fi
    return 1
}

# Function to check if the session is over SSH
# this is stupid but whatever
is_ssh() {
    [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]
}

# Prints all warnings in $KNOWN_USERS_FILE to the terminal
# Mentions each user that has a warning message set, and prints the warning message
print_warnings(){
    for user in $(awk -F: '$4 != "" {print $1}' "$KNOWN_USERS_FILE" | sort -u); do
        warn_msg=$(get_warning "$user")
        if [ -n "$warn_msg" ]; then
            echo "Warning from $user: $warn_msg"
        fi
    done
}

# Function to list known users and currently online users
list_all() {
    echo "All known users (from $KNOWN_USERS_FILE):"
    if [ -f "$KNOWN_USERS_FILE" ]; then
        awk -F: 'NF {printf "  %s (given_name: %s, terminals: %s)\n", $1, $2, $3}' "$KNOWN_USERS_FILE" | sort -u
    else
        echo "  (none)"
    fi

    echo
}

# Function to prompt sys-admins about log file management
manage_log() {
    if ! is_sysadmin || [ "$log_size" -lt $((MAX_LOG_SIZE * 75 / 100)) ]; then
        return
    fi

    list_all
    echo "$user is recognized as sysadmin and $LOG_FILE is $log_size bytes (>=75% of $MAX_LOG_SIZE)."
    PS3="Choose an action for $LOG_FILE: "
    options=("Backup" "Clear" "Skip")
    if is_ssh; then
        options+=("Download")
    fi

    select opt in "${options[@]}"; do
        case $opt in
            Backup)
                timestamp=$(date +%Y%m%d_%H%M%S)
                cp "$LOG_FILE" "$LOG_FILE.bak.$timestamp"
                echo "Backed up $LOG_FILE to $LOG_FILE.bak.$timestamp"
                break
                ;;
            Download)
                if is_ssh; then
                    echo "Downloading $LOG_FILE in an SSH session."
                    echo "From your local machine, run: scp ${user}@$(hostname):$(pwd)/$LOG_FILE ./"
                else
                    echo "Download option is only available over SSH."
                fi
                break
                ;;
            Clear)
                > "$LOG_FILE"
                echo "Cleared $LOG_FILE"
                break
                ;;
            Skip)
                echo "No action taken on $LOG_FILE"
                break
                ;;
            *)
                echo "Invalid option. Please choose again."
                ;;
        esac
    done
}

# Function to log the user session, processes, and check for Docker daemon
log_session() {
    local session_data
    local processes
    local session_users
    local docker_count

    session_data=$(w)
    processes=$(ps -e)
    session_users=$(w -h | wc -l)

    # Log the session data and processes to the log file
    echo "$user: Opened a terminal" >> "$LOG_FILE"
    echo "$session_data" >> "$LOG_FILE"

    # Welcome message with user count and terminal count
    echo "Including you, there are $session_users users online!"
    list_all
    print_warnings

    echo "There are $(grep bash <<< "$processes" | wc -l) terminals open!"


    docker_count=$(grep docker <<< "$processes" | wc -l)
    if [ "$docker_count" -ge 1 ]; then
        echo "Docker Daemon is running!"
        echo "Type phelp to work on project"
    else
        echo "DOCKER DAEMON IS NOT RUNNING!!!!"
        echo "ITS THE END OF THE WORLD!!!"
        echo "SAVE YOURSELF!!!"
    fi
}

# Function to display help information
show_help() {
    cat <<'EOF'
LoonLog - User Session Logger for Loon-E Project

Usage: ./LoonLog [OPTIONS]

Options:
  -i, --login       Log current user as logging in (default behavior)
  -o, --logout      Remove current user from KNOWN_USERS_FILE
  -h, --help        Show this help message and exit
  -v, --version     Show version information and exit
  -w, --warn        Show a warning to all logins
  -r, --remove-warn Remove the warning message for the current user

Examples:
  ./LoonLog              # Normal login, checks log size, manages logs
  ./LoonLog -i           # Explicit login
  ./LoonLog -o           # Log user out
  ./LoonLog -h           # Show help
  ./LoonLog -v           # Show version information
  ./LoonLog -w "Cheese is delicious"
  ./LoonLog -r           # Remove the warning message for the current user

Notes:
  - This script is typically invoked in ~/.bashrc for login
  - LoonExit script should be invoked in ~/.bash_logout for logout
EOF
}

# Function to handle login
handle_login() {
    get_user
    check_log_size
    manage_log
    log_session
}

# Function to handle logout
handle_logout() {
    # Logout must stay non-interactive.
    user=$(whoami)

    if ! update_session "$user" "-1"; then
        echo "User $user was not tracked in $KNOWN_USERS_FILE" >&2
        return 1
    fi

    echo "User $user logged out" >> "$LOG_FILE"
    echo "Goodbye $user!"
}

# Function to parse command-line arguments
parse_arguments() {
    case "${1:-}" in
        -i|--login)
            handle_login
            ;;
        -o|--logout)
            handle_logout
            ;;
        -h|--help)
            show_help
            ;;
        -v|--version)
            echo "Loon-Env version 2.0.0"
            echo "LoonLog version 2.0.2"
            ;; 
        -w|--warn)
            user=$(whoami)
            add_warning "$user" "${2:-}" # Pass the second argument as the warning message, if provided
            ;;
        -r|--remove-warn)
            user=$(whoami)
            remove_warning "$user"
            ;;
        "")
            # No arguments, default to login
            handle_login
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use -h or --help for usage information"
            exit 1
            ;;
    esac
}

# ------------------ MAIN ------------------

parse_arguments "$@"