# Logger for the Loon-E project. It logs user sessions, processes, and checks for the Docker daemon.
#
# Why is it using a KNOWN_USERS_FILE? 
#   Because Loon-e is blind and can't tell who you are.
#   No, it's because the log in is dysfunct and we want to be able to track users. 
#   robo users are users that the system can't identify, so we ask them for a name and save it to a file.
# Usage:
#   This is to be invoked in bashrc.
#   ensure the the script is invoked in bash_logout to log when users exit the terminal.

# ------------------ CONSTANTS ------------------
# Max size for the log file in bytes (e.g., 5 MiB)
MAX_LOG_SIZE=$((5 * 1024 * 1024))
LOG_FILE="${LOG_FILE:-log.txt}"

# The file to store known users. Each line is in the format "username:PID".
KNOWN_USERS_FILE="${KNOWN_USERS_FILE:-known_users.txt}"
DEFAULT_USER="robo" # Change this to whatever you set your default user is.

# Ensure directory structure exists
mkdir -p "$(dirname "$KNOWN_USERS_FILE")"
mkdir -p "$(dirname "$LOG_FILE")"

touch "$KNOWN_USERS_FILE"
touch "$LOG_FILE"

# We can't make objects so pretend these are objects functions
# ------------------ User Functions ------------------
# User:
# - username - the name of the user, either from whoami or from user input for robo users
# - terminals - the number of terminals the user has open, determined by counting bash processes
# - warn_msg - a warning message set by the user to be displayed to all users when they log in

# Function to add users in KNOWN_USERS_FILE
create_user() {
    local username="$1"
    local terminals="${2:-1}" # Default to 1 terminal if not provided
    echo "$username:$terminals" >> "$KNOWN_USERS_FILE"
}

# Function to remove user session from KNOWN_USERS_FILE
remove_user_session() {
    local username="$1"
    local amount="${2:-1}" # Default to 1 terminal if not provided
    # Create a temporary file
    local temp_file=$(mktemp)

    # Use awk to find the user and update the terminal count, or add the user if not found
    awk -F: -v user="$username" -v amount="$amount" '
        BEGIN { found=0 }
        $1 == user {
            found=1
            terminals = $2 - amount
            if (terminals <= 0) {
                next # Skip printing this user, effectively removing them
            }
            print user ":" terminals
            next
        }
        { print }
    ' "$KNOWN_USERS_FILE" > "$temp_file"

    # Replace original file with temp file
    mv "$temp_file" "$KNOWN_USERS_FILE"
}

# Function to add user session to KNOWN_USERS_FILE
add_user_session() {
    local username="$1"
    local amount="${2:-1}" # Default to 1 terminal if not provided
    # Create a temporary file
    local temp_file=$(mktemp)

    # Use awk to find the user and update the terminal count, or add the user if not found
    awk -F: -v user="$username" -v amount="$amount" '
        BEGIN { found=0 }
        $1 == user {
            found=1
            terminals = $2 + amount
            print user ":" terminals
            next
        }
        { print }
        END {
            if (found == 0) {
                print user ":" amount
            }
        }
    ' "$KNOWN_USERS_FILE" > "$temp_file"

    # Replace original file with temp file
    mv "$temp_file" "$KNOWN_USERS_FILE"
}

# Warnings not implemented yet
get_warning() {
    local user="$1"
    local warn_msg=$(grep "^$user:*:" "$KNOWN_USERS_FILE" | cut -d: -f2-)
    if [ -n "$warn_msg" ]; then
        echo "Warning for $user: $warn_msg"
    fi
}

add_warning() {
    user="$1"
    session="$2"
    warn_msg="${3:-}" # Optional second argument for the warning message, but we'll prompt if it's not provided
    warning=$(get_warning "$user")
    if [ -n "$warning" ]; then
        echo "User $user already has a warning message set: $warning"
        read -p "Do you want to overwrite the existing warning message? (y/n) " confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            echo "Keeping existing warning message."
            return
        fi
        echo "Overwriting existing warning message."
        # continue to overwrite the warning message
    fi

    while true; do

        if [ -z "$warn_msg" ]; then # This is to stop users from being stupid
            echo "Warning message cannot be empty. Please enter a warning message."
        elif [[ "$warn_msg" == *":"* ]]; then #this is due to the delimiter used in KNOWN_USERS_FILE
            echo "Warning message cannot contain colons. Please enter a warning message without colons."
        elif [[ "$warn_msg" == *$'\n'* ]]; then #This is due to how we read the data on KNOWN_USERS_FILE
            echo "Warning message cannot contain newlines. Please enter a warning message without newlines."
        else
            read -p "Are you sure you want to set the warning message to '$warn_msg'? (y/n) " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                echo "Setting warning message to '$warn_msg'"
                echo "$user:$session:$warn_msg" >> "$KNOWN_USERS_FILE"
                echo "Warning message set successfully."
            fi
            break
        fi
        # Down here to emulate do while
        read -p "Enter a warning message to display to all users on login: " warn_msg

    done
}

remove_warning() {
    user="$1"
    warning=$(get_warning "$user")
    if [ -z "$warning" ]; then
        echo "User $user does not have a warning message set."
        return
    fi

    read -p "Are you sure you want to remove the warning message for $user? (y/n) " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        # Create a temporary file
        local temp_file=$(mktemp)

        # Use awk to remove the warning message for the user
        awk -F: -v user="$user" '
            BEGIN { OFS=":" }
            $1 == user { print $1 ":" "" }
            $1 != user { print }
        ' "$KNOWN_USERS_FILE" > "$temp_file"

        # Replace original file with temp file
        mv "$temp_file" "$KNOWN_USERS_FILE"
        echo "Warning message removed successfully."
    else
        echo "Keeping existing warning message."
    fi
}


# at the bottom of the functions section is the parse arguements function invokation, which is the main entry point.
# ------------------ FUNCTIONS ------------------

# Function to get the username, with special handling for "robo" users
get_username() {
    user=$(whoami)
    if [ "$DEFAULT_USER" == "$user" ]; then
        echo "Loon-e is blind and can't tell who you are"
        echo "Login with your username or ask a sysadmin to add you"


        while true; do
            read -p "What is your name: " user

            if [ -z "$user" ]; then
                echo "Name cannot be empty. Please enter your name."
                continue
            fi

            if command -v "$user" >/dev/null 2>&1; then
                echo "The name '$user' is a command name. Please choose a different username."
                continue
            fi

            if grep -qF "$user:" "$KNOWN_USERS_FILE"; then
                echo "The name '$user' is already registered. Please enter a different name."
                continue
            fi


            break
        done
    fi
    # Writting every time a new terminal opens is a bit excessive
    # but it ensures we have a record of all users that have ever logged in, even if they are "robo" users.
    # See the LoonExit Script for bash logout
    add_user_session "$user"
    echo "Saved '$user' to $KNOWN_USERS_FILE"
    echo "Welcome Aboard $user!"
}

# Function to determine log size
get_log_size() {
    if [ -f "$LOG_FILE" ]; then
        log_size=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
    else
        log_size=0
    fi
}

# Function to check log size and warn if it's too large
check_log_size() {
    get_log_size
    if [ "$log_size" -ge "$MAX_LOG_SIZE" ]; then
        echo "Warning: $LOG_FILE is too large ($log_size bytes, max $MAX_LOG_SIZE bytes)."
        echo "Consider backing up or clearing it."
    fi
}

# Function to check if the user is a sys-admin
# also stupid but whatever
is_sysadmin() {
    if id -nG "$user" | grep -qwE 'sudo|wheel'; then
        return 0
    fi
    return 1
}

# Function to check if the session is over SSH
# this is stupid but whatever
is_ssh() {
    [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ]
}

# Function to list known users and currently online users
list_all() {
    # Ensure current user is logged to KNOWN_USERS_FILE
    if ! grep -qF "$user:" "$KNOWN_USERS_FILE" 2>/dev/null; then
        echo "$user:$$" >> "$KNOWN_USERS_FILE"
    fi

    echo "All known users (from $KNOWN_USERS_FILE):"
    if [ -f "$KNOWN_USERS_FILE" ]; then
        awk 'NF' "$KNOWN_USERS_FILE" | sort -u | awk -F: '{printf "  %s (PID: %s)\n", $1, $2}'
    else
        echo "  (none)"
    fi

    echo
}

# Function to prompt sys-admins about log file management
manage_log() {
    if ! is_sysadmin || [ "$log_size" -lt $((MAX_LOG_SIZE * 75 / 100)) ]; then
        return
    fi

    list_all
    echo "$user is recognized as sysadmin and $LOG_FILE is $log_size bytes (>=75% of $MAX_LOG_SIZE)."
    PS3='Choose an action for $LOG_FILE: '
    options=("Backup" "Clear" "Skip")
    if is_ssh; then
        options+=("Download")
    fi

    select opt in "${options[@]}"; do
        case $opt in
            Backup)
                timestamp=$(date +%Y%m%d_%H%M%S)
                cp "$LOG_FILE" "$LOG_FILE.bak.$timestamp"
                echo "Backed up $LOG_FILE to $LOG_FILE.bak.$timestamp"
                break
                ;;
            Download)
                if is_ssh; then
                    echo "Downloading $LOG_FILE in an SSH session."
                    echo "From your local machine, run: scp ${user}@$(hostname):$(pwd)/$LOG_FILE ./"
                else
                    echo "Download option is only available over SSH."
                fi
                break
                ;;
            Clear)
                > "$LOG_FILE"
                echo "Cleared $LOG_FILE"
                break
                ;;
            Skip)
                echo "No action taken on $LOG_FILE"
                break
                ;;
            *)
                echo "Invalid option. Please choose again."
                ;;
        esac
    done
}

# Function to log the user session, processes, and check for Docker daemon
log_session() {
    session_data=$(w)
    processes=$(ps -e)

    echo "$user: Opened a terminal" >> "$LOG_FILE"
    echo "$session_data" >> "$LOG_FILE"
    echo "Including you, there are $(tail -n -1 <<< "$session_data" | wc -l) users online!"
    list_all

    echo "There are $(grep bash <<< "$processes" | wc -l) terminals open!"

    docker_count=$(grep docker <<< "$processes" | wc -l)
    if [ "$docker_count" -ge 1 ]; then
        echo "Docker Daemon is running!"
        echo "Type phelp to work on project"
    else
        echo "DOCKER DAEMON IS NOT RUNNING!!!!"
        echo "ITS THE END OF THE WORLD!!!"
        echo "SAVE YOURSELF!!!"
    fi
}

# remove_user_on_exit() {}
# Replaced with remove_user_session() which decrements the terminal count instead of removing the user entirely, since users can have multiple terminals open.

# Function to display help information
show_help() {
    cat <<'EOF'
LoonLog - User Session Logger for Loon-E Project

Usage: ./LoonLog [OPTIONS]

Options:
  -i, --login       Log current user as logging in (default behavior)
  -o, --logout      Remove current user from KNOWN_USERS_FILE
  -h, --help        Show this help message and exit
  -v, --version     Show version information and exit
  -w, --warn        Show a warning to all logins
  -r, --remove-warn Remove the warning message for the current user

Examples:
  ./LoonLog              # Normal login, checks log size, manages logs
  ./LoonLog -i           # Explicit login
  ./LoonLog -o           # Log user out
  ./LoonLog -h           # Show help
  ./LoonLog -v           # Show version information
  ./LoonLog -w "Cheese is delicious"
  ./LoonLog -r           # Remove the warning message for the current user

Notes:
  - This script is typically invoked in ~/.bashrc for login
  - LoonExit script should be invoked in ~/.bash_logout for logout
EOF
}

# Function to handle login
handle_login() {
    get_username
    check_log_size
    manage_log
    log_session
}

# Function to handle logout
handle_logout() {
    user=$(whoami)
    remove_user_session "$user" "1" # Decrement terminal count by 1
    echo "User $user (PID: $pid) logged out" >> "$LOG_FILE"
    echo "Goodbye $user!"
}

# Function to parse command-line arguments
parse_arguments() {
    case "${1:-}" in
        -i|--login)
            handle_login
            ;;
        -o|--logout)
            handle_logout
            ;;
        -h|--help)
            show_help
            ;;
        -v|--version)
            echo "Loon-Env version 2.0.0"
            echo "LoonLog version 1.0.2"
            ;; 
        -w|--warn)
            user=$(whoami)
            add_warning "$user" "${2:-}" # Pass the second argument as the warning message, if provided
            ;;
        -r|--remove-warn)
            user=$(whoami)
            remove_warning "$user"
            ;;
        "")
            # No arguments, default to login
            handle_login
            ;;
        *)
            echo "Unknown option: $1"
            echo "Use -h or --help for usage information"
            exit 1
            ;;
    esac
}

# ------------------ MAIN ------------------

parse_arguments "$@"