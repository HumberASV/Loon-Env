# The LoonE script is a convenient wrapper for managing the Docker environment for the Loon-E project.
# Version
LOONE_VERSION="2.0.0"
# Usage:
#   LoonE [OPTIONS] [IMAGE_NAME]
# Options:
#   -h, --help   show this help message and exit
#   -s, --start  start the Docker container if it's not running
#   -e, --enter  enter the Docker container
#   -b, --build   build the Docker image if it doesn't exist
#   -r, --run     run Loon-E with the specified image, building and starting as needed
#   -q, --quack   returns "Quack!" (because why not) This is not the same message as the help command for funsies.
# If no options are provided, it defaults to a quick help message

#---------------------- CONSTANTS ------------------
# Use second argument as image name, default to setup_img
IMAGE_NAME="${2:-${LOON_E_IMAGE:-loon-e:latest}}"

# Asset directory and dockerfile for builds
ASSET_DIR="${ASSET_DIR:-/usr/share/Loon-Env}"
DOCKERFILE="${DOCKERFILE:-$ASSET_DIR/LoonE/Dockerfile}"

#---------------------- FUNCTIONS ------------------
# Provide help information and exit
show_help(){
        cat <<'EOF'
Usage: LoonE [IMAGE_NAME]

The LoonE script is a convenient wrapper for managing the Docker environment for the Loon-E project. 
It can build the Docker image, start the container, and enter it with a single command. :)

Options:
IMAGE_NAME   optional image name (default: setup_img)
-h, --help   show this help message and exit
-s, --start  start the Docker container if it's not running
-e, --enter  enter the Docker container
-b, --build   build and run services
-q, --quack   what does this do? Try it and find out!
-v, --version   show version information and exit
EOF
}

# Function to check if container is running; it's stupid but readable
# Returns:
#   0 if running
#   1 if not running
is_container_running() {
    if docker ps --filter "name=^/${IMAGE_NAME}$" --filter "status=running" --format '{{.Names}}' | grep -xq "${IMAGE_NAME}"; then
        return 0 # Running
    else
        return 1 # Not running
    fi
}

# Function to check if image is built
# also stupid but readable
# Returns:
#   0 if image exists
#   1 if image does not exist
is_image_built() {
    if docker image inspect "$IMAGE_NAME" &> /dev/null; then
        return 0 # Image exists
    else
        return 1 # Image does not exist
    fi
}

# function to enter the container if it's not running
enter_container() {
    xhost +local:root
    xhost +local:docker

    # Check if the container is running
    if ! is_container_running; then
        echo "Container '$IMAGE_NAME' is not running or does not exist."
        echo "Start it with LoonS ${IMAGE_NAME} (or equivalent) first."
        exit 1
    fi

    docker exec -it "$IMAGE_NAME" bash 
}

# This function will compose both the Zedx and Loon-E ros containers
run_services() {
    export DISPLAY="${DISPLAY:-:1}"
    local host_xauth="${XAUTHORITY:-$HOME/.Xauthority}"
    local docker_xauth="/tmp/.docker.xauth"

    if command -v xauth >/dev/null 2>&1; then
        touch "$docker_xauth"
        xauth nlist "$DISPLAY" | sed -e 's/^..../ffff/' | xauth -f "$docker_xauth" nmerge - >/dev/null 2>&1 || true
        chmod 644 "$docker_xauth"
        export XAUTHORITY="$docker_xauth"
    else
        export XAUTHORITY="$host_xauth"
    fi

    if [ ! -f "$XAUTHORITY" ]; then
        echo "Warning: Xauthority file not found at '$XAUTHORITY'. X11 apps like rviz2 may fail to start."
    fi

    DISPLAY="$DISPLAY" xhost +local:root
    DISPLAY="$DISPLAY" xhost +local:docker
    echo Building zed and loone containers...
    docker compose -f "$ASSET_DIR/compose.yaml" up -d
}

# Function to parse command-line arguments
parse_arguments() {
    local user=$(whoami)
    local pid=$$
    case "${1:-}" in
        -s|--start)
            start_container
            ;;
        -e|--enter)
            enter_container
            ;;
        -b|--build)
            run_services
            ;;
        -h|--help)
            show_help
            ;;
        -q|--quack)
            echo "Quack!"
            ;;
        -v|--version)
            echo "Loon-Env version ${LOON_ENV_VERSION}"
            echo "LoonE version ${LOONE_VERSION}"
            echo "Quack! Am I a boat or a duck?"
            ;;
        *) 
            echo "No valid option provided. Use -h or --help for usage information."
            exit 1
            ;;
    esac
}

parse_arguments "$@"
